{
    "version": 2,
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "Access-Control-Allow-Origin", "value": "*" },
                { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
            ]
        },
        {
            "source": "/data/(.*).json",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, no-cache" }
            ]
        }
    ]
}
